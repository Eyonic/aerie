{
  "name": "aerie-desktop",
  "version": "1.0.0",
  "license": "MIT",
  "description": "Aerie — your private cloud, on your desktop",
  "author": "Aerie contributors",
  "homepage": "https://github.com/Eyonic/aerie",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --linux --win"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "app.aerie.desktop",
    "productName": "Aerie",
    "directories": { "output": "release" },
    "files": ["main.js", "preload.js", "config.html", "default-server.json", "build/icon.png"],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Network",
      "icon": "build/icon.png",
      "maintainer": "Aerie"
    },
    "deb": {
      "artifactName": "aerie_${version}_${arch}.${ext}"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "artifactName": "Aerie-Setup-${version}.${ext}"
    }
  }
}
