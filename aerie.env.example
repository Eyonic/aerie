# Aerie environment — copy to aerie.env and fill in your values.
# Every integration is OPTIONAL: leave a block's URL(s) unset and the matching
# feature simply reports "not configured" in the UI instead of breaking.

# ============ Core ============
# HTTP port the server listens on inside the container.
PORT=8200
# Server-local timezone used by the nightly backup scheduler. Use an IANA name.
TZ=Etc/UTC
# Nightly recovery-bundle start hour in that timezone (0-23), and number of
# complete bundles retained locally after a successful run.
BACKUP_SCHEDULE_HOUR=3
BACKUP_RETENTION=14
# Secret for signing login tokens. Auto-generated and persisted under DATA_DIR
# if unset, but setting a fixed value (e.g. `openssl rand -hex 32`) is recommended.
JWT_SECRET=
# Public HTTPS address of this Aerie (optional; used in UI hints for
# features that need a secure context: casting, mic, PWA install).
PUBLIC_URL=https://cloud.example.com
# LAN address (optional). Native apps learn PUBLIC_URL + LAN_URL from
# /api/health and switch between them automatically when one is unreachable.
LAN_URL=http://192.168.0.10:8200
# Set to 1 only when Aerie is behind exactly one trusted reverse-proxy hop.
# This lets Express use that proxy's client IP and HTTPS protocol information.
TRUST_PROXY=0
# Optional comma-separated browser origins allowed to call the API. Leave
# empty for the normal same-origin web app and native clients.
CORS_ORIGINS=
# NOTE: integration endpoints and credentials can also be configured in the
# admin Integrations page. In-app values override env.
# Legacy upgrade seed only. New installs choose one or more target languages
# per account under Settings → AI & Privacy.
TRANSLATE_LANG=
# App state directory inside the container (DB, thumbnails, generated files).
DATA_DIR=/data
# Per-user file storage root (each user gets an immutable private directory).
FILES_ROOT=/files
# Shared read-mostly media library root.
MEDIA_ROOT=/media
# Where downloads are stored (defaults to DATA_DIR/downloads if unset).
DOWNLOADS_DIR=/downloads
# First-run admin account. Without ADMIN_PASSWORD a random one is generated
# and printed ONCE to the container log.
ADMIN_USER=admin
ADMIN_PASSWORD=
# Set to 1 to also create a demo/demo try-it-out account on first run.
SEED_DEMO=0

# ============ Media (movies/TV via Jellyfin, audiobooks via Audiobookshelf) ============
# Enables the Films/Series/Music sections.
JELLYFIN_URL=http://192.168.0.10:8096
JELLYFIN_API_KEY=
# Enables the Audiobooks section.
ABS_URL=http://192.168.0.10:13378
ABS_API_KEY=

# ============ Requests (media wishlist) ============
# Enables movie/TV requests via Jellyseerr.
JELLYSEERR_URL=http://192.168.0.10:5055
JELLYSEERR_API_KEY=
# Enables music (artist) requests via Lidarr.
LIDARR_URL=http://192.168.0.10:8686
LIDARR_API_KEY=

# ============ AI ============
# Local AI chat via Ollama.
OLLAMA_URL=http://192.168.0.10:11434
OLLAMA_MODEL=llama3.2:latest
# Cloud AI chat via DeepSeek (key required; URL/model have sane defaults).
DEEPSEEK_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# AI image generation (ComfyUI by convention).
SD_URL=http://192.168.0.10:9000
# Speech-to-text (Wyoming Whisper — a TCP socket, not HTTP).
WHISPER_URL=http://192.168.0.10:10300
# AI music generation (ACE-Step).
ACESTEP_URL=http://192.168.0.10:8019

# ============ Misc ============
# LAN IPv4 fallback for Chromecast discovery on that /24. This is not the
# server process bind address. TOWER_HOST is a legacy alias.
SERVER_HOST=192.168.0.10
#TOWER_HOST=192.168.0.10
# Override the /24 subnet scanned for Cast devices (defaults to the subnet
# derived from CAST_SUBNET/JELLYFIN_URL/SERVER_HOST, in that order).
CAST_SUBNET=192.168.0.0
